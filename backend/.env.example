NODE_ENV=development
# Optional explicit env (if set, APP_ENV overrides NODE_ENV)
# APP_ENV=development

# Telegram bot by environment:
# - development: TELEGRAM_BOT_TEST_TOKEN (fallback TELEGRAM_TOKEN_DEV -> TELEGRAM_TOKEN)
# - production:  TELEGRAM_BOT_PROD_TOKEN (fallback TELEGRAM_TOKEN_PROD -> TELEGRAM_TOKEN)
# - webhook/legacy alias: TELEGRAM_BOT_TOKEN
TELEGRAM_BOT_TEST_TOKEN=
TELEGRAM_BOT_PROD_TOKEN=
TELEGRAM_TOKEN_DEV=
TELEGRAM_TOKEN_PROD=
# Legacy fallback token (kept for backward compatibility)
TELEGRAM_TOKEN=
# Optional alias used by some integrations
TELEGRAM_BOT_TOKEN=

# Telegram owner chat by environment:
# - development: MY_CHAT_ID_TEST (fallback MY_CHAT_ID_DEV -> MY_CHAT_ID)
# - production:  MY_CHAT_ID_PROD (fallback MY_CHAT_ID)
# - webhook/legacy alias: YOUR_TELEGRAM_CHAT_ID
MY_CHAT_ID_TEST=
MY_CHAT_ID_DEV=
MY_CHAT_ID_PROD=
# Legacy fallback chat id
MY_CHAT_ID=
# Optional alias used by webhook integrations
YOUR_TELEGRAM_CHAT_ID=

# Optional manual lock path. If empty, default by env:
# - development: .bot.dev.lock
# - production:  .bot.prod.lock
BOT_LOCK_FILE=

OPENROUTER_API_KEY=
# Model chinh (uu tien cao nhat):
AI_MODEL=deepseek/deepseek-r1:free
# Model rieng cho flow viet bai: /post, /news, /rewrite, edit draft
# Neu model chua "claude", mac dinh se goi qua SHOPAIKEY_BASE_URL.
CONTENT_WRITER_MODEL=claude-sonnet-4-6
CONTENT_WRITER_PROVIDER=auto
# AI_MODEL=deepseek/deepseek-r1
AI_MAX_TOKENS=1500
OPENROUTER_MODEL=deepseek/deepseek-r1
OPENROUTER_DEEP_MODEL=deepseek/deepseek-r1
OPENROUTER_RETRY_MODELS=deepseek/deepseek-chat,meta-llama/llama-3.1-70b-instruct,openrouter/auto
OPENROUTER_TRANSFORMS=middleman
# Khi AI_MODEL co ':free', mac dinh KHONG fallback sang paid.
# Dat true neu muon cho phep fallback sang model tra phi khi model free loi.
OPENROUTER_ALLOW_PAID_FALLBACK=false
OPENROUTER_SITE_URL=https://the-little-coder.local
OPENROUTER_APP_NAME=The Little Coder AI Agent
GOOGLE_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
GEMINI_IMAGE_FALLBACK_MODELS=gemini-3.1-flash-image-preview,gemini-3-pro-image-preview,gemini-2.5-flash
GOOGLE_AI_KEY=
GEMINI_IMAGE_PROMPT_MODEL=gemini-2.5-flash
GEMINI_REFERENCE_IMAGE_PATH=assets/anh-mau.png
ENABLE_IMAGE_GENERATION=false
# Storage layer:
# - postgres (default): lưu roadmap/drafts/schedules vào PostgreSQL
# - file: lưu như cũ bằng JSON
STORAGE_DRIVER=postgres
# false: không fallback sang JSON file khi Postgres thiếu config/lỗi kết nối
STORAGE_ALLOW_FILE_FALLBACK=false
# false: không tự migrate dữ liệu từ roadmap.json/drafts.json sang DB
STORAGE_MIGRATE_JSON=false
# Railway Postgres URL
DATABASE_URL=
# Optional Postgres tuning
PG_POOL_MAX=5
PG_REQUIRE_SSL=false
# Legacy file storage (chỉ dùng khi STORAGE_DRIVER=file)
ROADMAP_FILE=roadmap.json
DRAFT_FILE=drafts.json
SCHEDULED_POST_FILE=scheduled-posts.json
SCHEDULE_AUTO_ENABLED=true
SCHEDULE_POLL_CRON=*/1 * * * *
SCHEDULE_TIMEZONE=Asia/Ho_Chi_Minh
SCHEDULE_UTC_OFFSET=+07:00
ROADMAP_AUTO_ENABLED=true
# Test nhanh: >0 thì scheduler chạy mỗi N phút và override lịch 3 khung giờ.
ROADMAP_TEST_INTERVAL_MINUTES=0
# true: chỉ cho phép tối đa 1 draft chờ duyệt; false: cron vẫn tạo draft tiếp dù chưa duyệt bài trước.
ROADMAP_REQUIRE_REVIEW_BEFORE_NEXT=true
# true: nếu hôm nay không có bài khớp type theo lịch thì lấy đại bài pending kế tiếp (không khuyến nghị cho flow series).
ROADMAP_ALLOW_CROSS_TYPE_FALLBACK=false
# Chỉ khôi phục bài PROCESSING về PENDING khi quá N phút (tránh loop khi job còn đang chạy).
ROADMAP_PROCESSING_STALE_MINUTES=20
# Dùng khi ROADMAP_TEST_INTERVAL_MINUTES=0:
# 3 khung giờ chạy mỗi ngày
ROADMAP_CRON_MORNING=0 8 * * *
ROADMAP_CRON_NOON=0 12 * * *
ROADMAP_CRON_NIGHT=0 20 * * *
# Legacy single cron (giữ tương thích cũ)
ROADMAP_CRON=0 8 * * *
ROADMAP_TIMEZONE=Asia/Ho_Chi_Minh

RESEARCH_PROVIDER=tavily
TAVILY_API_KEY=
SHOPAIKEY_API_KEY=
SHOPAIKEY_BASE_URL=https://api.shopaikey.com/v1
SHOPAIKEY_MODEL=grok-2
RESEARCH_MAX_RESULTS_PER_QUERY=8
RESEARCH_MAX_TOTAL_RESULTS=16

FB_PAGE_ID=
FB_PAGE_TOKEN=

# Backward compatible names (optional)
FACEBOOK_PAGE_ID=
FACEBOOK_ACCESS_TOKEN=
GROQ_MODEL=
GROQ_DEEP_MODEL=
